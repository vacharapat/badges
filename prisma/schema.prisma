generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("STUDENT")
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  coursesTaught  Course[]       @relation("CourseTeachers")
  enrollments    Enrollment[]
  badgesEarned   StudentBadge[] @relation("StudentBadges")
  badgesAwarded  StudentBadge[] @relation("TeacherAwarded")
}

model Course {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  teachers    User[]   @relation("CourseTeachers")
  badges      Badge[]
  enrollments Enrollment[]
}

model Enrollment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  student   User   @relation(fields: [studentId], references: [id])
  studentId String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String

  @@unique([studentId, courseId])
}

model Badge {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  missions  String
  createdAt DateTime @default(now())

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  studentBadges StudentBadge[]
}

model StudentBadge {
  id        String   @id @default(cuid())
  awardedAt DateTime @default(now())

  student   User   @relation("StudentBadges", fields: [studentId], references: [id])
  studentId String
  badge     Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  awardedBy   User   @relation("TeacherAwarded", fields: [awardedById], references: [id])
  awardedById String

  @@unique([studentId, badgeId])
}
